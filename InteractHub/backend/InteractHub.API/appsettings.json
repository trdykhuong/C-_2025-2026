{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=InteractHubDb;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "Jwt": {
    "Key": "InteractHubSuperSecretKey_ChangeInProduction_Min32Chars!",
    "Issuer": "InteractHub",
    "Audience": "InteractHubClient",
    "ExpiresHours": "24"
  },
  "Frontend": {
    "Url": "http://localhost:5173"
  },
  "Azure": {
    "BlobStorage": {
      "ConnectionString": "YOUR_AZURE_BLOB_CONNECTION_STRING",
      "ContainerName": "interacthub"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
